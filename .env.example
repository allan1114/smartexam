# ========================================
# Google Gemini API Configuration
# ========================================

# 📌 方式 1：直接 API 密鑰（開發模式）
# 獲取方式：https://ai.google.dev/
# ⚠️ 警告：不要將此密鑰提交到版本控制，會暴露給客戶端
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 📌 方式 2：後端代理（生產模式 - 推薦）
# 使用 `/api/proxy-gemini` 端點來保護 API 密鑰
# 設置為 'true' 以啟用代理模式
VITE_USE_GEMINI_PROXY=false

# 代理 URL（如果在自定義路徑上）
# VITE_GEMINI_PROXY_URL=/api/proxy-gemini

# ========================================
# Vercel 環境變數（生產部署）
# ========================================

# 🔐 服務器端 API 密鑰（僅用於後端代理）
# 在 Vercel 儀表板中設置，不要在此暴露
# GEMINI_API_KEY=your_gemini_api_key_here

